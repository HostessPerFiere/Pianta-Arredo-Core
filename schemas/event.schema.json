{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/spatial-intelligence/event.schema.json",
  "title": "Spatial Intelligence Event",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "projectId",
    "correlationId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "eventVersion": {
      "type": "string",
      "minLength": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "subjectId": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "causationId": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
